                    Skriv på WhatsApp
                </a>
            </div>
            
            <div class="footer-col">
                <h4>Information</h4>
                <ul>
                    <li><a href="about.html">Om Os</a></li>
                    <li><a href="club.html">Strikkeklub</a></li>
                    <li><a href="#">Fragt & Returnering</a></li>
                    <li><a href="#">Persondatapolitik</a></li>
                </ul>
            </div>
        </div> 
        
        <div class="footer-bottom">
            <a href="index.html">
                <img src="images/footer-logo.png" alt="Garnstuen Logo" class="footer-logo">
            </a>
            <p>Daph9&GPS© 2026. Forfiner hver en maske.</p>
        </div>
    </footer>

    <script>
        // Mobile Menu Toggle
        const mobileToggle = document.getElementById('mobile-toggle');
        const navMenu = document.getElementById('nav-menu');
        const mobileReserve = document.getElementById('mobile-reserve');
        
        mobileToggle.addEventListener('click', () => { 
            navMenu.classList.toggle('active'); 
            if(navMenu.classList.contains('active')) {
                mobileReserve.style.display = 'block';
            } else {
                mobileReserve.style.display = 'none';
            }
        });

        // Quantity Selector Logic
        function updateQty(change) {
            const input = document.getElementById('qty-input');
            let currentValue = parseInt(input.value) || 1;
            let newValue = currentValue + change;
            if (newValue >= 1) {
                input.value = newValue;
            }
        }
    </script>
</body>
</html>
